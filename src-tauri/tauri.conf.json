{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AET",
  "version": "3.2.7",
  "identifier": "com.afm.dev",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../src-ui run dev",
    "beforeBuildCommand": "npm --prefix ../src-ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "AKI File Activity Monitor",
        "width": 1400,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "AXtremeTS",
    "targets": "all",
    "resources": [
      "binaries/*",
      "extract_icon.ps1"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}